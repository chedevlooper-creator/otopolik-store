{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "npm run *": "allow",
      "npm install": "allow",
      "npm ci": "allow",
      "npx vitest *": "allow",
      "npx playwright *": "allow",
      "npx tsc *": "allow",
      "npx eslint *": "allow",
      "node scripts/*": "allow",
      "node .claude/skills/run-otopolik-store/driver.mjs *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git add *": "allow",
      "npx convex *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "taskkill *": "ask",
      "Remove-Item *": "ask",
      "rm *": "deny"
    }
  }
}
