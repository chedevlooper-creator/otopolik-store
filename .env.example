# ============================================================================
# OTO POLİK — Environment Variables (Vercel Deploy İçin)
# ============================================================================
# Kopyalayıp .env.local olarak kaydedin, gerçek değerlerle doldurun.
# Vercel'de: Settings → Environment Variables ekranına bu değerleri girin.
#
# NEXT_PUBLIC_ önekli değişkenler client tarafında da görünür (Header, Footer).
# Sunucu tarafı sırları (admin şifresi) için öneksiz değişken kullanın.
# ============================================================================

# --- Site URL (Zorunlu) ---
NEXT_PUBLIC_SITE_URL=https://otopolik.com

# --- Convex (Veritabanı + Realtime) ---
# Convex Cloud projesi URL'iniz. Önce:
#   1) npx convex login --vercel   (Vercel hesabınızla giriş)
#   2) npx convex dev              (geliştirme için)
#   3) npx convex deploy --prod    (production için)
# değerler otomatik oluşur; buraya NEXT_PUBLIC_CONVEX_URL'i yapıştırın.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Production'da Convex deploy için (Vercel marketplace entegrasyonu)
CONVEX_DEPLOY_KEY=

# --- Site Kimlik & İletişim (Yayın Öncesi Zorunlu) ---
NEXT_PUBLIC_SITE_PHONE=0537 267 26 89
NEXT_PUBLIC_SITE_WHATSAPP_NUMBER=905372672689
NEXT_PUBLIC_SITE_EMAIL=info@otopolik.com
NEXT_PUBLIC_SITE_ADDRESS=İOSB Mah. Sefaköy San. Sit. 7.Blok No:10-12, Başakşehir/İstanbul
NEXT_PUBLIC_SITE_INSTAGRAM=https://instagram.com/otopolik

# --- Kargo & Lojistik ---
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=3500
NEXT_PUBLIC_SHIPPING_FEE=99
NEXT_PUBLIC_ESTIMATED_DISPATCH=1-3 iş günü
NEXT_PUBLIC_BUSINESS_HOURS=Pazartesi - Cumartesi, 09:00 - 18:00

# --- Konfigüratör Fiyatlandırma (TL) ---
NEXT_PUBLIC_MAT_BASE_PRICE=3500
NEXT_PUBLIC_MAT_HEEL_PAD_PRICE=500
NEXT_PUBLIC_MAT_TRUNK_PRICE=1750

# --- Ödeme Sağlayıcısı (Opsiyonel — ileride eklenecek) ---
# iyzico:
# IYZIPAY_API_KEY=
# IYZIPAY_SECRET_KEY=
# IYZIPAY_URI=https://sandbox-api.iyzipay.com

# --- Admin Panel ---
# Sunucu tarafı — sadece server bundle'da. Production'da mutlaka değiştirin.
ADMIN_PASSWORD=admin123
# Oturum imzalama ve Convex admin çağrıları için anahtar (tercih edilen).
# Tanımlı değilse ADMIN_PASSWORD kullanılır. Hem Vercel'de hem Convex
# ortam değişkenlerinde AYNI değerle tanımlanmalıdır:
#   npx convex env set ADMIN_SECRET <değer>
ADMIN_SECRET=

