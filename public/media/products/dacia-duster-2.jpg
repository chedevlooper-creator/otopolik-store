    <style>
        :root{
            --drs-primary: #950200;
            --drs-hover: #590000;
            --drs-green: #009933;
        }

        html { -webkit-text-size-adjust: 100%; }
        body {
            background-color: #f8f9fa;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            margin: 0;
            padding: 0;
            text-rendering: optimizeLegibility;
        }

        img {
            max-width: 100%;
            height: auto;
        }

        .sr-only{
            position:absolute !important;
            width:1px !important;
            height:1px !important;
            padding:0 !important;
            margin:-1px !important;
            overflow:hidden !important;
            clip:rect(0,0,0,0) !important;
            white-space:nowrap !important;
            border:0 !important;
        }

        .hide-scroll::-webkit-scrollbar { display:none; }
        .hide-scroll { -ms-overflow-style:none; scrollbar-width:none; }

        /* ============================================== */
        /* AKILLI KULLANICI MENÜSÜ (DROPDOWN) CSS ZIRHI   */
        /* ============================================== */
        .drs-user-wrapper { position: relative; height: 100%; display: flex; align-items: center; }
        .drs-user-dropdown {
            position: absolute;
            top: 100%;
            right: 0;
            width: 250px;
            background: transparent;
            padding-top: 15px; /* Menü ile link arasındaki boşluk köprüsü */
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 9000;
            pointer-events: none;
        }
        .drs-user-wrapper:hover .drs-user-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
            pointer-events: auto;
        }
        .drs-user-dropdown-inner {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .drs-user-dropdown-link {
            padding: 10px 20px;
            font-size: 12px;
            font-weight: 700;
            color: #475569;
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: all 0.2s;
        }
        .drs-user-dropdown-link:hover { background-color: #f8fafc; color: #1e293b; }
        .drs-user-dropdown-link i { width: 20px; text-align: center; margin-right: 8px; color: #94a3b8; font-size: 14px; }
        /* ============================================== */

        .mob-ann-wrapper{
            height:36px;
            overflow:hidden;
            background:#ffffff;
            position:relative;
            contain:layout paint;
        }
        .mob-ann-inner{
            display:flex;
            flex-direction:column;
            animation:vertAnnounce 12s infinite;
            will-change:transform;
        }
        .mob-ann-item{
            height:36px;
            display:flex;
            align-items:center;
            justify-content:center;
            font-weight:800;
            color:#1e293b;
            width:100%;
            text-align:center;
            flex-shrink:0;
        }
        @media (max-width:767px){ .mob-ann-item{ font-size:11.5px; } }
        @media (min-width:768px){ .mob-ann-item{ font-size:14px; } }

        @keyframes vertAnnounce{
            0%,28%{ transform:translateY(0); }
            33%,61%{ transform:translateY(-36px); }
            66%,94%{ transform:translateY(-72px); }
            100%{ transform:translateY(0); }
        }

        .drawer-overlay{
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.6);
            z-index:9900;
            opacity:0;
            visibility:hidden;
            transition:opacity .3s ease, visibility .3s ease;
        }
        .drawer-overlay.active{
            opacity:1;
            visibility:visible;
        }
        .drawer-panel{
            position:fixed;
            top:0;
            bottom:0;
            width:340px;
            max-width:90vw;
            background:#fff;
            z-index:9999;
            transition:transform .3s cubic-bezier(.4,0,.2,1);
            box-shadow:0 0 25px rgba(0,0,0,.15);
            display:flex;
            flex-direction:column;
        }
        .drawer-right{ right:0; transform:translateX(100%); }
        .drawer-right.active{ transform:translateX(0); }
        .drawer-left{ left:0; transform:translateX(-100%); }
        .drawer-left.active{ transform:translateX(0); }

        .live-search-results{
            display:none;
            position:absolute;
            top:100%;
            left:0;
            right:0;
            background:#fff;
            box-shadow:0 10px 25px rgba(0,0,0,.1);
            border-radius:0 0 12px 12px;
            z-index:8500;
            max-height:400px;
            overflow-y:auto;
            overflow-x:hidden;
            border:1px solid #eee;
            border-top:none;
            contain:layout paint;
        }
        .live-search-results.active{ display:block; }
        .live-search-results::-webkit-scrollbar{ width:5px; }
        .live-search-results::-webkit-scrollbar-thumb{ background:#cbd5e1; border-radius:10px; }

        @media (max-width:767px){
            .live-search-results.active{
                position:fixed !important;
                top:130px !important;
                left:0 !important;
                right:0 !important;
                bottom:0 !important;
                height:calc(100dvh - 92px) !important;
                max-height:none !important;
                z-index:100000 !important;
                border-radius:0 !important;
                overflow-y:auto !important;
                background:#f8f9fa;
                display:block !important;
                overscroll-behavior:contain;
                padding-bottom:16px;
            }
        }

        .page-transition-overlay{
            position:fixed;
            inset:0;
            background:#ffffff;
            z-index:999999;
            opacity:0;
            pointer-events:none;
            transition:opacity .25s ease, transform .25s ease;
            transform:scale(1.02);
        }
        .page-transition-overlay.active{
            opacity:1;
            pointer-events:auto;
            transform:scale(1);
        }

        .cart-badge-anim{ transition:transform .3s cubic-bezier(.175,.885,.32,1.275); }

        .text-drs-safe{ color:#c24100 !important; }
        .bg-drs-safe{ background-color:#c24100 !important; }
        .bg-drs-safe:hover{ background-color:#a33600 !important; }
        .text-green-safe{ color:#007b00 !important; }

        .py-3\.55{ padding-top:.60rem; padding-bottom:.60rem; padding-left:1rem; }
        .py-33{ padding-top:.6rem; padding-bottom:.6rem; }

        ::placeholder,
        :-ms-input-placeholder,
        ::-ms-input-placeholder{
            color:#64748b !important;
            opacity:1 !important;
            font-size:13px !important;
            letter-spacing:.5px;
        }


        /* =====================================================
           ANASAYFA TEK H1 - LOGONUN HEMEN ALTINDA KESİNTİSİZ TICKER
           - Masaüstünde logo başlangıcıyla aynı hizada ve logo genişliğinde.
           - İki eş kopya sayesinde hareket yalnızca sağdan sola devam eder.
           - İkinci kopya aria-hidden ve H1 değildir; sayfada tek H1 korunur.
           - Sabit yükseklik ve transform animasyonu CLS oluşturmaz.
        ===================================================== */
        .drs-header-home-heading-row{
            width:100%;
            height:22px;
            min-height:22px;
            margin:0;
            border-top:0;
            border-bottom:1px solid #e2e8f0;
            background:#fff;
            overflow:hidden;
            contain:layout paint;
        }
        .drs-header-home-heading-inner{
            width:100%;
            max-width:1350px;
            height:22px;
            margin:0 auto;
            padding:0 16px;
            display:flex;
            align-items:center;
            justify-content:flex-start;
        }
        .drs-header-home-heading-viewport{
            width:220px;
            max-width:220px;
            height:22px;
            overflow:hidden;
            display:flex;
            align-items:center;
        }
        .drs-header-home-heading-track{
            display:flex;
            align-items:center;
            width:max-content;
            max-width:none;
            white-space:nowrap;
            will-change:transform;
            transform:translate3d(0,0,0);
            animation:drsHeaderHomeHeadingMove 30s linear infinite;
        }
        .drs-header-home-heading-segment{
            display:inline-flex;
            align-items:center;
            flex:0 0 auto;
            gap:7px;
            padding-right:28px;
            white-space:nowrap;
        }
        .drs-header-home-heading-title,
        .drs-header-home-heading-description{
            display:block;
            flex:0 0 auto;
            margin:0;
            padding:0;
            line-height:22px;
            white-space:nowrap;
            font-family:inherit;
            font-style:normal;
            font-weight:400 !important;
            letter-spacing:0;
        }
        .drs-header-home-heading-title{
            font-size:11.5px;
            color:#334155;
        }
        .drs-header-home-heading-description{
            font-size:10.5px;
            color:#475569;
        }
        .drs-header-home-heading-separator{
            display:block;
            flex:0 0 auto;
            font-size:10px;
            line-height:22px;
            font-weight:400;
            color:#94a3b8;
        }
        .drs-header-home-heading-row:hover .drs-header-home-heading-track,
        .drs-header-home-heading-row:focus-within .drs-header-home-heading-track{
            animation-play-state:paused;
        }
        @keyframes drsHeaderHomeHeadingMove{
            from{ transform:translate3d(0,0,0); }
            to{ transform:translate3d(-50%,0,0); }
        }
        @media (max-width:767px){
            .drs-header-home-heading-row,
            .drs-header-home-heading-inner,
            .drs-header-home-heading-viewport{
                height:22px;
                min-height:22px;
            }
            .drs-header-home-heading-inner{ padding:0 8px; }
            .drs-header-home-heading-viewport{
                width:100%;
                max-width:none;
            }
            .drs-header-home-heading-title{ font-size:10.5px; }
            .drs-header-home-heading-description{ font-size:9.5px; }
            .drs-header-home-heading-track{ animation-duration:32s; }
        }
        @media (prefers-reduced-motion:reduce){
            .drs-header-home-heading-track{
                width:100%;
                min-width:0;
                animation:none !important;
                transform:none !important;
                overflow:hidden;
            }
            .drs-header-home-heading-segment{
                min-width:0;
                padding-right:0;
            }
            .drs-header-home-heading-segment-copy{ display:none; }
            .drs-header-home-heading-description{
                min-width:0;
                overflow:hidden;
                text-overflow:ellipsis;
            }
        }
            .drs-header-home-heading-description{
                overflow:hidden;
                text-overflow:ellipsis;
            }
        }
    </style>

