<script>
(function () {
  var loaded = false;
  var primarySrc = "https://drstuning.com/chatbot-widget/chatbot-widget.js?v=2.0";
  var fallbackSrc = "https://otoaksesuarshop.com/chatbot-widget/chatbot-widget.js?v=2.0";
  var storeId = "1";
  var apiBase = "https://otoaksesuarshop.com/chatbot-test";
  var mobileMedia = window.matchMedia ? window.matchMedia('(max-width: 767px)') : { matches: false };

  document.documentElement.classList.add('drs-chatbot-mobile-nav-mode');

  function applyAttrs(el) {
    el.async = true;
    el.setAttribute('data-store-id', storeId);
    el.setAttribute('data-api-base', apiBase);
  }

  function callOpenWhenReady() {
    window.__DRS_CHATBOT_PENDING_OPEN__ = true;
    var tries = 0;
    var timer = setInterval(function () {
      tries++;
      if (typeof window.drsOpenChatbotWidget === 'function') {
        clearInterval(timer);
        window.drsOpenChatbotWidget();
      } else if (tries > 60) {
        clearInterval(timer);
      }
    }, 100);
  }

  function loadDrsChatbot(openAfterLoad) {
    if (openAfterLoad) {
      window.__DRS_CHATBOT_PENDING_OPEN__ = true;
    }

    if (window.__DRS_CHATBOT_WIDGET_LOADED__ || typeof window.drsOpenChatbotWidget === 'function') {
      if (openAfterLoad) callOpenWhenReady();
      return;
    }

    if (loaded || !document.body) {
      if (openAfterLoad) callOpenWhenReady();
      return;
    }

    loaded = true;
    var s = document.createElement('script');
    s.src = primarySrc;
    applyAttrs(s);
    s.onload = function () { if (openAfterLoad) callOpenWhenReady(); };
    s.onerror = function () {
      if (primarySrc === fallbackSrc) return;
      var t = document.createElement('script');
      t.src = fallbackSrc;
      applyAttrs(t);
      t.onload = function () { if (openAfterLoad) callOpenWhenReady(); };
      document.body.appendChild(t);
    };
    document.body.appendChild(s);
  }

  window.drsLoadChatbotWidget = loadDrsChatbot;
  window.drsOpenChatbotFromFooter = function (event) {
    if (event && event.preventDefault) event.preventDefault();
    loadDrsChatbot(true);
  };

  function scheduleDesktopLazyLoad() {
    if (mobileMedia.matches) return;
    window.addEventListener('load', function () {
      var idle = window.requestIdleCallback || function (cb) { return setTimeout(cb, 3000); };
      idle(function () { loadDrsChatbot(false); }, { timeout: 4500 });
    }, { once: true });

    ['mousemove', 'scroll', 'keydown'].forEach(function (eventName) {
      window.addEventListener(eventName, function () {
        if (!mobileMedia.matches) loadDrsChatbot(false);
      }, { once: true, passive: true });
    });
  }

  scheduleDesktopLazyLoad();
})();
</script>

<script>
(function () {
    if (typeof window.drsPrepareGoogleLogin === 'function') return;

    window.drsPrepareGoogleLogin = function (form, fallbackPath) {
        try {
            var currentPath = (window.location.pathname || '/') + (window.location.search || '');
            var blocked = /^\/(social_auth(?:\.php)?|giris(?:\.php)?|kayit(?:\.php)?|cikis|admin)(?:\/|$)/i;
            var returnPath = blocked.test(currentPath) ? String(fallbackPath || '/hesabim') : currentPath;

            if (!returnPath || returnPath.charAt(0) !== '/' || returnPath.indexOf('//') === 0 || returnPath.length > 1200) {
                returnPath = '/hesabim';
            }

            var host = (window.location.hostname || '').toLowerCase().replace(/^www\./, '');
            var cookie = 'drs_social_return=' + encodeURIComponent(returnPath)
                + '; Path=/; Max-Age=600; SameSite=Lax';

            if (window.location.protocol === 'https:') cookie += '; Secure';
            if (host === 'drstuning.com' || host === 'drstuning.com.tr' || host === 'otoaksesuarshop.com') {
                cookie += '; Domain=' + host;
            }

            document.cookie = cookie;
        } catch (e) {
            // Cookie yazılamasa da sabit OAuth URL'si /hesabim dönüşüyle çalışır.
        }
        return true;
    };
})();
</script>

