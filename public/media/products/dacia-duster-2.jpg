</main>


<script>
/*
 * Anasayfa ürün görsel galerisi - V1.7
 * - Masaüstü: imlecin yatay konumu görseli belirler.
 * - Mobil/iOS: native touch event ile sağa-sola kaydırma.
 * - Üst ürün slider'ının yatay kaydırmayı çalması engellenir.
 * - Tek event delegation kullanır; kart başına ayrı listener oluşturmaz.
 */
(function () {
    'use strict';

    var pointerSwipeState = new WeakMap();
    var activeTouch = null;

    function findGallery(target) {
        if (!target || typeof target.closest !== 'function') return null;
        return target.closest('[data-drs-home-gallery]');
    }

    function galleryCount(gallery) {
        return Math.max(1, parseInt(gallery.getAttribute('data-count') || '1', 10));
    }

    function currentIndex(gallery) {
        return Math.max(0, parseInt(gallery.getAttribute('data-index') || '0', 10));
    }

    function galleryImages(gallery) {
        if (gallery._drsImages) return gallery._drsImages;
        try {
            var parsed = JSON.parse(gallery.getAttribute('data-images') || '[]');
            gallery._drsImages = Array.isArray(parsed) ? parsed : [];
        } catch (e) {
            gallery._drsImages = [];
        }
        return gallery._drsImages;
    }

    function ensureGallerySlides(gallery) {
        if (gallery.getAttribute('data-slides-ready') === '1') return;

        var images = galleryImages(gallery);
        var track = gallery.querySelector('.drs-home-gallery-track');
        if (!track || images.length < 2) {
            gallery.setAttribute('data-slides-ready', '1');
            return;
        }

        var productName = gallery.getAttribute('data-name') || 'Ürün';
        var placeholder = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';

        for (var i = 1; i < images.length; i++) {
            var slide = document.createElement('span');
            slide.className = 'drs-home-gallery-slide';
            slide.setAttribute('data-gallery-slide', String(i));

            var image = document.createElement('img');
            image.src = placeholder;
            image.setAttribute('data-src', images[i]);
            image.alt = productName + ' - Görsel ' + (i + 1);
            image.width = 420;
            image.height = 420;
            image.loading = 'lazy';
            image.decoding = 'async';
            image.setAttribute('fetchpriority', 'low');
            image.draggable = false;

            slide.appendChild(image);
            track.appendChild(slide);
        }

        gallery.setAttribute('data-slides-ready', '1');
    }

    function hydrateImage(gallery, index) {
        if (index > 0) ensureGallerySlides(gallery);
        var image = gallery.querySelector('[data-gallery-slide="' + index + '"] img[data-src]');
        if (!image) return;

        var src = image.getAttribute('data-src');
        if (!src) return;

        image.setAttribute('src', src);
        image.removeAttribute('data-src');
    }

    function hydrateAround(gallery, index) {
        var count = galleryCount(gallery);
        if (count > 1) ensureGallerySlides(gallery);
        hydrateImage(gallery, index);
        if (index > 0) hydrateImage(gallery, index - 1);
        if (index + 1 < count) hydrateImage(gallery, index + 1);
    }

    function hydrateAll(gallery) {
        if (gallery.getAttribute('data-hydrated') === '1') return;
        gallery.setAttribute('data-hydrated', '1');
        ensureGallerySlides(gallery);

        gallery.querySelectorAll('img[data-src]').forEach(function (image) {
            var src = image.getAttribute('data-src');
            if (!src) return;
            image.setAttribute('src', src);
            image.removeAttribute('data-src');
        });
    }

    function setGalleryIndex(gallery, nextIndex) {
        var count = galleryCount(gallery);
        var index = Math.max(0, Math.min(count - 1, nextIndex));
        var current = currentIndex(gallery);

        hydrateAround(gallery, index);
        if (current === index) return;

        gallery.setAttribute('data-index', String(index));

        var track = gallery.querySelector('.drs-home-gallery-track');
        if (track) {
            track.style.transform = 'translate3d(-' + (index * 100) + '%, 0, 0)';
        }

        gallery.querySelectorAll('[data-gallery-dot]').forEach(function (dot) {
            dot.classList.toggle(
                'is-active',
                parseInt(dot.getAttribute('data-gallery-dot') || '-1', 10) === index
            );
        });
    }

    function suppressGalleryClick(gallery) {
        gallery.setAttribute('data-suppress-click', '1');
        window.setTimeout(function () {
            gallery.removeAttribute('data-suppress-click');
        }, 700);
    }

    function isDesktopPointer(event) {
        if (window.innerWidth < 768) return false;
        return !event.pointerType || event.pointerType === 'mouse';
    }

    function hasNativeTouch() {
        return ('ontouchstart' in window) || ((navigator.maxTouchPoints || 0) > 0);
    }

    function getTouchByIdentifier(touchList, identifier) {
        if (!touchList) return null;
        for (var i = 0; i < touchList.length; i++) {
            if (touchList[i].identifier === identifier) {
                return touchList[i];
            }
        }
        return null;
    }

    /* -----------------------------
       MASAÜSTÜ MOUSE
    ----------------------------- */
    document.addEventListener('pointerover', function (event) {
        var gallery = findGallery(event.target);
        if (!gallery || !isDesktopPointer(event)) return;
        hydrateAll(gallery);
    }, true);

    document.addEventListener('pointermove', function (event) {
        var gallery = findGallery(event.target);
        if (!gallery || !isDesktopPointer(event)) return;

        var rect = gallery.getBoundingClientRect();
        if (rect.width <= 0) return;

        var count = galleryCount(gallery);
        var relativeX = Math.max(0, Math.min(rect.width - 0.01, event.clientX - rect.left));
        var index = Math.floor((relativeX / rect.width) * count);
        setGalleryIndex(gallery, index);
    }, {capture: true, passive: true});

    document.addEventListener('pointerout', function (event) {
        var gallery = findGallery(event.target);
        if (!gallery || !isDesktopPointer(event)) return;
        if (event.relatedTarget && gallery.contains(event.relatedTarget)) return;
        setGalleryIndex(gallery, 0);
    }, true);

    /* -----------------------------
       MOBİL/iOS NATIVE TOUCH
       PointerUp iOS'ta dış slider yüzünden iptal olabildiği için
       touchstart/move/end akışı ayrıca yönetilir.
    ----------------------------- */
    document.addEventListener('touchstart', function (event) {
        var gallery = findGallery(event.target);
        if (!gallery || galleryCount(gallery) < 2 || event.touches.length !== 1) {
            activeTouch = null;
            return;
        }

        var touch = event.touches[0];
        var index = currentIndex(gallery);

        activeTouch = {
            gallery: gallery,
            identifier: touch.identifier,
            startX: touch.clientX,
            startY: touch.clientY,
            lastX: touch.clientX,
            lastY: touch.clientY,
            index: index,
            axis: '',
            moved: false
        };

        hydrateAround(gallery, index);
    }, {capture: true, passive: true});

    document.addEventListener('touchmove', function (event) {
        if (!activeTouch) return;

        var touch = getTouchByIdentifier(event.touches, activeTouch.identifier);
        if (!touch) return;

        activeTouch.lastX = touch.clientX;
        activeTouch.lastY = touch.clientY;

        var deltaX = touch.clientX - activeTouch.startX;
        var deltaY = touch.clientY - activeTouch.startY;
        var absX = Math.abs(deltaX);
        var absY = Math.abs(deltaY);

        if (!activeTouch.axis && Math.max(absX, absY) >= 7) {
            activeTouch.axis = absX > (absY * 1.05) ? 'x' : 'y';
        }

        if (activeTouch.axis !== 'x') return;

        activeTouch.moved = true;

        /*
         * Kritik iPhone fix:
         * Ürün listesindeki yatay overflow alanının dokunmayı devralmasını engeller.
         * Dikey kaydırmaya dokunulmaz.
         */
        if (event.cancelable) {
            event.preventDefault();
        }
        event.stopPropagation();
    }, {capture: true, passive: false});

    document.addEventListener('touchend', function (event) {
        if (!activeTouch) return;

        var state = activeTouch;
        activeTouch = null;

        var touch = getTouchByIdentifier(event.changedTouches, state.identifier);
        var endX = touch ? touch.clientX : state.lastX;
        var endY = touch ? touch.clientY : state.lastY;
        var deltaX = endX - state.startX;
        var deltaY = endY - state.startY;
        var horizontal = state.axis === 'x' || Math.abs(deltaX) > (Math.abs(deltaY) * 1.05);

        if (!horizontal || Math.abs(deltaX) < 28) return;

        if (event.cancelable) {
            event.preventDefault();
        }
        event.stopPropagation();

        setGalleryIndex(state.gallery, state.index + (deltaX < 0 ? 1 : -1));
        suppressGalleryClick(state.gallery);
    }, {capture: true, passive: false});

    document.addEventListener('touchcancel', function () {
        activeTouch = null;
    }, {capture: true, passive: true});

    /* -----------------------------
       POINTER FALLBACK
       Touch event üretmeyen kalem/eski cihazlar için.
    ----------------------------- */
    document.addEventListener('pointerdown', function (event) {
        if (event.pointerType === 'touch' && hasNativeTouch()) return;

        var gallery = findGallery(event.target);
        if (!gallery || galleryCount(gallery) < 2) return;

        var mobileLike = window.innerWidth < 768 || event.pointerType === 'touch' || event.pointerType === 'pen';
        if (!mobileLike) return;

        var index = currentIndex(gallery);
        pointerSwipeState.set(gallery, {
            pointerId: event.pointerId,
            startX: event.clientX,
            startY: event.clientY,
            index: index
        });

        hydrateAround(gallery, index);
    }, {capture: true, passive: true});

    document.addEventListener('pointerup', function (event) {
        if (event.pointerType === 'touch' && hasNativeTouch()) return;

        var gallery = findGallery(event.target);
        if (!gallery) return;

        var state = pointerSwipeState.get(gallery);
        if (!state || state.pointerId !== event.pointerId) return;
        pointerSwipeState.delete(gallery);

        var deltaX = event.clientX - state.startX;
        var deltaY = event.clientY - state.startY;

        if (Math.abs(deltaX) < 28 || Math.abs(deltaX) <= Math.abs(deltaY) * 1.05) return;

        setGalleryIndex(gallery, state.index + (deltaX < 0 ? 1 : -1));
        suppressGalleryClick(gallery);
    }, {capture: true, passive: true});

    document.addEventListener('pointercancel', function (event) {
        var gallery = findGallery(event.target);
        if (gallery) pointerSwipeState.delete(gallery);
    }, true);

    /* Kaydırma sonrası ürün linkinin yanlışlıkla açılmasını engelle. */
    document.addEventListener('click', function (event) {
        var gallery = findGallery(event.target);
        if (!gallery || gallery.getAttribute('data-suppress-click') !== '1') return;
        event.preventDefault();
        event.stopPropagation();
    }, true);

    document.addEventListener('dragstart', function (event) {
        var gallery = findGallery(event.target);
        if (gallery) event.preventDefault();
    }, true);
})();
</script>


<script>
document.addEventListener('DOMContentLoaded', function () {
    function pad2(n) {
        return String(n).padStart(2, '0');
    }

    window.drsUpdateTimedCampaignCountdowns = function () {
        document.querySelectorAll('[data-timed-campaign-target]').forEach(function (box) {
            const targetRaw = box.getAttribute('data-timed-campaign-target');
            const mode = box.getAttribute('data-timed-campaign-mode') || 'active';
            const output = box.querySelector('[data-countdown-output]');

            if (!targetRaw || !output) return;

            const target = new Date(targetRaw).getTime();
            const now = new Date().getTime();
            let diff = target - now;

            if (mode === 'expired') {
                output.innerHTML = '<span>00</span><small>Gün</small><span>00</span><small>Saat</small><span>00</span><small>Dk</small><span>00</span><small>Sn</small>';
                return;
            }

            if (diff <= 0) {
                output.innerHTML = '<span>00</span><small>Gün</small><span>00</span><small>Saat</small><span>00</span><small>Dk</small><span>00</span><small>Sn</small>';

                if (!box.dataset.refreshTriggered) {
                    box.dataset.refreshTriggered = '1';
                    setTimeout(function () {
                        drsRefreshTimedCampaignBox(true);
                    }, 1200);
                }
                return;
            }

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            diff -= days * (1000 * 60 * 60 * 24);

            const hours = Math.floor(diff / (1000 * 60 * 60));
            diff -= hours * (1000 * 60 * 60);

            const minutes = Math.floor(diff / (1000 * 60));
            diff -= minutes * (1000 * 60);

            const seconds = Math.floor(diff / 1000);

            output.innerHTML =
                '<span>' + pad2(days) + '</span><small>Gün</small>' +
                '<span>' + pad2(hours) + '</span><small>Saat</small>' +
                '<span>' + pad2(minutes) + '</span><small>Dk</small>' +
                '<span>' + pad2(seconds) + '</span><small>Sn</small>';
        });
    };

    window.drsRefreshTimedCampaignBox = function (force) {
        const slot = document.getElementById('drsTimedCampaignHomeSlot');
        if (!slot) return;

        const formData = new FormData();
        formData.append('action', 'get_timed_campaign_box');
        formData.append('_ts', String(Date.now()));

        fetch(window.location.pathname, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
            cache: 'no-store'
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            if (!res || res.status !== 'ok') return;

            const currentBox = slot.querySelector('[data-timed-campaign-mode]');
            const currentMode = currentBox ? currentBox.getAttribute('data-timed-campaign-mode') : '';
            const incomingMode = res.mode || '';

            if (force || currentMode !== incomingMode || res.html) {
                slot.innerHTML = res.html || '';
                window.drsUpdateTimedCampaignCountdowns();
            }
        })
        .catch(function (err) {
            console.warn('Süreli kampanya kutusu yenilenemedi:', err);
        });
    };

    window.drsUpdateTimedCampaignCountdowns();
    window.drsRefreshTimedCampaignBox(false);
    setInterval(window.drsUpdateTimedCampaignCountdowns, 1000);
    setInterval(function () { window.drsRefreshTimedCampaignBox(false); }, 30000);
});
</script>



<script>
// Araç seçimi URL zırhı: /marka/{marka}/{model}/{yil}
document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('btn_search_garage');
    if (!btn) return;

    function slugifyGarageText(value) {
        value = String(value || '').trim().toLowerCase();
        var map = {'ı':'i','ğ':'g','ü':'u','ş':'s','ö':'o','ç':'c','İ':'i','Ğ':'g','Ü':'u','Ş':'s','Ö':'o','Ç':'c'};
        value = value.replace(/[ıüğşöçİĞÜŞÖÇ]/g, function (ch) { return map[ch] || ch; });
        value = value.replace(/&/g, ' ve ');
        value = value.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').replace(/-+/g, '-');
        return value;
    }

    function selectedSlug(selectId) {
        var el = document.getElementById(selectId);
        if (!el || !el.value) return '';
        var opt = el.options[el.selectedIndex];
        var raw = String(el.value || '').trim();
        if (raw !== '' && !/^\d+$/.test(raw)) {
            return slugifyGarageText(raw);
        }
        return slugifyGarageText(opt ? opt.text : raw);
    }

    btn.addEventListener('click', function (e) {
        var brand = selectedSlug('sel_brand');
        var model = selectedSlug('sel_model');
        var year = selectedSlug('sel_year');

        if (!brand || !model || !year) return;

        e.preventDefault();
        e.stopPropagation();
        if (e.stopImmediatePropagation) e.stopImmediatePropagation();

        window.location.href = '/marka/' + encodeURIComponent(brand) + '/' + encodeURIComponent(model) + '/' + encodeURIComponent(year);
    }, true);
});
</script>

<script>
/* Ana sayfa ürün modülleri lazy DOM yükleyici - V1.12
   - Yeni index çıktısında kalan kartları AJAX ile getirir.
   - Eski/OPcache kalmış tam çıktıda fazla kartları canlı DOM'dan ayırır
     ve kullanıcı sona yaklaştıkça yeniden ekler.
*/
(function () {
    'use strict';

    function appendDeferred(track) {
        var queue = track && track.__drsDeferredSlides;
        if (!queue || !queue.length) {
            if (track) track.setAttribute('data-done', '1');
            return;
        }

        var batch = parseInt(track.getAttribute('data-batch') || '8', 10);
        var fragment = document.createDocumentFragment();
        var count = 0;

        while (queue.length && count < batch) {
            fragment.appendChild(queue.shift());
            count++;
        }

        track.appendChild(fragment);
        track.setAttribute('data-offset', String(parseInt(track.getAttribute('data-offset') || '0', 10) + count));

        if (!queue.length) {
            track.setAttribute('data-done', '1');
        }
    }

    function loadMore(track) {
        if (!track || track.getAttribute('data-loading') === '1' || track.getAttribute('data-done') === '1') return;

        if (track.__drsDeferredSlides && track.__drsDeferredSlides.length) {
            track.setAttribute('data-loading', '1');
            appendDeferred(track);
            track.removeAttribute('data-loading');
            return;
        }

        var offset = parseInt(track.getAttribute('data-offset') || '0', 10);
        var total = parseInt(track.getAttribute('data-total') || '0', 10);
        var batch = parseInt(track.getAttribute('data-batch') || '8', 10);
        var moduleId = parseInt(track.getAttribute('data-module-id') || '0', 10);

        if (!moduleId || offset >= total) {
            track.setAttribute('data-done', '1');
            return;
        }

        track.setAttribute('data-loading', '1');
        var params = new URLSearchParams({
            home_module_cards: '1',
            module_id: String(moduleId),
            offset: String(offset),
            limit: String(batch)
        });

        fetch(window.location.pathname + '?' + params.toString(), {
            credentials: 'same-origin',
            headers: {'X-Requested-With': 'XMLHttpRequest'}
        })
        .then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        })
        .then(function (data) {
            if (!data || data.status !== 'ok') return;
            if (data.html) track.insertAdjacentHTML('beforeend', data.html);
            track.setAttribute('data-offset', String(data.next_offset || offset));
            if (data.done) track.setAttribute('data-done', '1');
            if (window.drsFixDynamicAccessibility) window.drsFixDynamicAccessibility(track);
            if (window.drsFixImageDimensions) window.drsFixImageDimensions(track);
        })
        .catch(function () {})
        .finally(function () {
            track.removeAttribute('data-loading');
        });
    }

    function maybeLoad(track) {
        var remaining = track.scrollWidth - (track.scrollLeft + track.clientWidth);
        if (remaining <= Math.max(320, track.clientWidth * 1.35)) loadMore(track);
    }

    function prepareLegacyTrack(track) {
        if (!track || track.hasAttribute('data-drs-home-module-slider')) return track;

        var slides = Array.prototype.slice.call(track.children).filter(function (node) {
            return node.nodeType === 1 && node.classList.contains('swiper-slide');
        });

        var initial = window.matchMedia('(max-width: 767px)').matches ? 6 : 8;
        if (slides.length <= initial) {
            track.setAttribute('data-done', '1');
            return track;
        }

        track.__drsDeferredSlides = slides.slice(initial);
        track.__drsDeferredSlides.forEach(function (slide) {
            if (slide.parentNode === track) track.removeChild(slide);
        });

        track.setAttribute('data-drs-home-module-slider', 'fallback');
        track.setAttribute('data-offset', String(initial));
        track.setAttribute('data-total', String(slides.length));
        track.setAttribute('data-batch', String(initial));
        return track;
    }

    function bindTrack(track) {
        if (!track || track.__drsLazyBound) return;
        track.__drsLazyBound = true;

        track.addEventListener('scroll', function () { maybeLoad(track); }, { passive: true });

        var container = track.closest('.group-slider');
        if (container) {
            container.querySelectorAll('.drs-nav-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    window.setTimeout(function () { maybeLoad(track); }, 260);
                }, { passive: true });
            });
        }
    }

    function init() {
        document.querySelectorAll('.prodSwiper .swiper-wrapper.items-stretch').forEach(function (track) {
            bindTrack(prepareLegacyTrack(track));
        });

        document.querySelectorAll('[data-drs-home-module-slider]').forEach(bindTrack);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
        init();
    }
})();
</script>

