 transition-colors flex-1">Suv Moonvisör Kep</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/suv-snorkel" aria-label="İncele: Suv Snorkel" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Suv Snorkel</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/tavan-citasi-ara-atkisi" aria-label="İncele: Tavan Çıtası - Ara Atkısı" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Tavan Çıtası - Ara Atkısı</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/tavan-sepeti" aria-label="İncele: Tavan Sepeti" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Tavan Sepeti</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/yan-basamak" aria-label="İncele: Yan Basamak" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Yan Basamak</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/oto-telefon-aksesuarlari" aria-label="İncele: Oto Telefon Aksesuarları" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Oto Telefon Aksesuarları</a><button aria-label="Alt Menüyü Aç" class="cat-toggle w-6 h-6 flex items-center justify-center text-slate-600 hover:text-drs-primary bg-slate-50 rounded-full"><i class="fa-solid fa-chevron-down text-[9px] transition-transform duration-300" aria-hidden="true"></i></button></div><ul class="hidden pl-3 border-l border-slate-100 ml-1 mt-0.5 space-y-0.5"><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/kablosuz-sarj" aria-label="İncele: Kablosuz Şarj" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Kablosuz Şarj</a></div></li></ul></li></ul></li></ul></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/yedek-parca" aria-label="İncele: Yedek Parça" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Yedek Parça</a><button aria-label="Alt Menüyü Aç" class="cat-toggle w-6 h-6 flex items-center justify-center text-slate-600 hover:text-drs-primary bg-slate-50 rounded-full"><i class="fa-solid fa-chevron-down text-[9px] transition-transform duration-300" aria-hidden="true"></i></button></div><ul class="hidden pl-3 border-l border-slate-100 ml-1 mt-0.5 space-y-0.5"><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/ayna-camlari" aria-label="İncele: Ayna Camları" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Ayna Camları</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/bagaj-amortisorleri" aria-label="İncele: Bagaj Amortisörleri" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Bagaj Amortisörleri</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/camurluk" aria-label="İncele: Çamurluk" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Çamurluk</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/camurluk-davlumbaz" aria-label="İncele: Çamurluk Davlumbaz" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Çamurluk Davlumbaz</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/ceki-demiri-ve-aksesuarlari" aria-label="İncele: Çeki Demiri Ve Aksesuarları" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Çeki Demiri Ve Aksesuarları</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/far-stop-sis-urunleri" aria-label="İncele: Far - Stop - Sis Ürünleri" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Far - Stop - Sis Ürünleri</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/kapi-kolu" aria-label="İncele: Kapı Kolu" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Kapı Kolu</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/kaput-amortisorleri" aria-label="İncele: Kaput Amortisörleri" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Kaput Amortisörleri</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/kaput-i-zolatoru" aria-label="İncele: Kaput İzolatörü" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Kaput İzolatörü</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/krom-urunleri" aria-label="İncele: Krom Ürünleri" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Krom Ürünleri</a><button aria-label="Alt Menüyü Aç" class="cat-toggle w-6 h-6 flex items-center justify-center text-slate-600 hover:text-drs-primary bg-slate-50 rounded-full"><i class="fa-solid fa-chevron-down text-[9px] transition-transform duration-300" aria-hidden="true"></i></button></div><ul class="hidden pl-3 border-l border-slate-100 ml-1 mt-0.5 space-y-0.5"><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/arka-tampon-citasi" aria-label="İncele: Arka Tampon Çıtası" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Arka Tampon Çıtası</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/on-tampon-citasi-cercevesi" aria-label="İncele: Ön Tampon Çıtası - Çerçevesi" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Ön Tampon Çıtası - Çerçevesi</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/sis-fari-sis-kapagi-krom" aria-label="İncele: Sis farı Sis Kapağı Krom" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Sis farı Sis Kapağı Krom</a></div></li></ul></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/marspiyel-kaplamasi-ve-aksesuarlari" aria-label="İncele: Marşpiyel Kaplaması Ve Aksesuarları" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Marşpiyel Kaplaması Ve Aksesuarları</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/on-arka-tampon-braket-bakalit" aria-label="İncele: Ön Arka Tampon Braket - Bakalit" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Ön Arka Tampon Braket - Bakalit</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/panjur-izgara-aksesuarlari" aria-label="İncele: Panjur &amp; Izgara Aksesuarları" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Panjur &amp; Izgara Aksesuarları</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/stepne-kapagi" aria-label="İncele: Stepne Kapağı" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Stepne Kapağı</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/tampon-alt-muhafaza-urunleri" aria-label="İncele: Tampon Alt Muhafaza Ürünleri" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Tampon Alt Muhafaza Ürünleri</a></div></li><li><div class="flex justify-between items-center py-1.5 border-b border-slate-50/50"><a href="https://drstuning.com/kategori/yan-aynalar" aria-label="İncele: Yan Aynalar" class="text-[13px] font-semibold text-slate-800 hover:text-drs-primary transition-colors flex-1">Yan Aynalar</a></div></li></ul></li></ul></div>
</aside>

<script>
    window.scrollNative = function(btn, dir) {
        const wrapper = btn.parentElement.querySelector('.native-carousel') || btn.parentElement.querySelector('.swiper-wrapper');
        if (wrapper && wrapper.firstElementChild) {
            const itemWidth = wrapper.firstElementChild.offsetWidth;
            wrapper.scrollBy({ left: dir * itemWidth, behavior: 'smooth' });
        }
    };

    function setPageScrollLock(locked) {
        if (locked) {
            document.body.style.overflow = 'hidden';
            document.documentElement.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = '';
            document.documentElement.style.overflow = '';
        }
    }

    function shouldLockDrawerScroll() {
        return window.innerWidth < 1024;
    }

    window.closeMobileSearch = function() {
        const mobSearchResults = document.getElementById('mobSearchResults');
        const mobSearchInput = document.getElementById('mobSearchInput');

        if (mobSearchResults) mobSearchResults.classList.remove('active');
        if (mobSearchInput) mobSearchInput.value = '';

        if (!document.querySelector('.drawer-panel.active')) {
            setPageScrollLock(false);
        }
    };

    // ==========================================
    // DİKKAT: SEPET FONKSİYONLARI YENİLENDİ!
    // URL'ler '/index.php' yerine '/cart/ajax_cart.php' oldu.
    // ==========================================

    window.drsFixImageDimensions = function(root) {
        root = root || document;

        var images = [];
        if (root.nodeType === 1 && root.matches && root.matches('img')) {
            images.push(root);
        }
        if (root.querySelectorAll) {
            images = images.concat(Array.prototype.slice.call(root.querySelectorAll('img')));
        }

        images.forEach(function(img) {
            if (img.hasAttribute('width') && img.hasAttribute('height')) return;

            var width = 0;
            var height = 0;

            if (img.closest('.prod-img-box')) {
                width = 420;
                height = 420;
            } else if (img.closest('.horiz-card-img')) {
                width = 220;
                height = 220;
            } else if (img.closest('#cartDrawerContent')) {
                width = 96;
                height = 96;
            } else if (img.closest('#drs-chatbot-widget-root')) {
                width = 64;
                height = 64;
            } else if (img.naturalWidth > 0 && img.naturalHeight > 0) {
                width = img.naturalWidth;
                height = img.naturalHeight;
            }

            if (width > 0 && !img.hasAttribute('width')) {
                img.setAttribute('width', String(width));
            }
            if (height > 0 && !img.hasAttribute('height')) {
                img.setAttribute('height', String(height));
            }
        });
    };

    window.drsFixDynamicAccessibility = function(root) {
        root = root || document;

        var chatbotButton = null;
        if (root.nodeType === 1 && root.matches && root.matches('#drs-chatbot-widget-button')) {
            chatbotButton = root;
        } else if (root.querySelector) {
            chatbotButton = root.querySelector('#drs-chatbot-widget-button');
        }

        if (chatbotButton) {
            var visibleText = String(chatbotButton.textContent || '').replace(/\s+/g, ' ').trim();
            if (visibleText !== '') {
                chatbotButton.removeAttribute('aria-label');
                chatbotButton.setAttribute('title', visibleText);
            }
        }
    };

    function drsObserveDynamicUi() {
        window.drsFixImageDimensions(document);
        window.drsFixDynamicAccessibility(document);

        if (!window.MutationObserver || !document.body) return;

        var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                mutation.addedNodes.forEach(function(node) {
                    if (!node || node.nodeType !== 1) return;
                    window.drsFixImageDimensions(node);
                    window.drsFixDynamicAccessibility(node);
                });
            });
        });

        observer.observe(document.body, { childList: true, subtree: true });
    }

    function updateCartUI(data) {
        if (data.status !== 'ok' && data.status !== 'success') return;

        // Sepet üstteki küçük yuvarlak badge'leri güncelle
        document.querySelectorAll('.drs-cart-badge').forEach(b => {
            if(data.total_items !== undefined) {
                b.innerText = data.total_items;
                b.style.transform = 'scale(1.4)';
                setTimeout(() => b.style.transform = 'scale(1)', 300);
            }
        });

        // Masaüstü "Toplam Tutar" yazısı varsa onu da güncelle
        const deskTotal = document.getElementById('cartTotalDesk');
        if (deskTotal && data.total_price !== undefined) deskTotal.innerText = data.total_price;

        // Çekmecenin içindeki asıl HTML'i bas!
        const drawerContent = document.getElementById('cartDrawerContent');
        if (drawerContent && data.cart_html !== undefined) {
            drawerContent.innerHTML = data.cart_html;
            window.drsFixImageDimensions(drawerContent);
            window.drsFixDynamicAccessibility(drawerContent);
        }
    }

    function addToCart(productId, event) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }

        let fd = new FormData();
        fd.append('action', 'add_to_cart');
        fd.append('product_id', productId);

        fetch('/cart/ajax_cart.php', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(data => {
                updateCartUI(data);
                toggleDrawer('cartDrawer'); // Eklenince çekmece açılsın
            });
    }

    function removeFromCart(productId, event) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }

        let fd = new FormData();
        fd.append('action', 'remove_from_cart');
        fd.append('product_id', productId);

        fetch('/cart/ajax_cart.php', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(updateCartUI); // Çekmeceyi anında silinen haliyle günceller
    }

    // Çekmece İçindeki + / - Butonları İçin YENİ Fonksiyon
    function updateCartQty(productId, qtyChange, event) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }
        
        let fd = new FormData();
        fd.append('action', 'update_cart_qty');
        fd.append('product_id', productId);
        fd.append('qty_change', qtyChange);

        fetch('/cart/ajax_cart.php', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(updateCartUI); // Adet değişince HTML'i ve fiyatları anında günceller
    }

    // Sayfa ilk yüklendiğinde veya sepet ikonu tıklandığında sepeti getir
    function getCart() {
        let fd = new FormData();
        fd.append('action', 'get_cart');

        fetch('/cart/ajax_cart.php', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(updateCartUI);
    }

    document.addEventListener('DOMContentLoaded', function () {
        drsObserveDynamicUi();

        // SAYFA AÇILIR AÇILMAZ SEPETİ YÜKLE
        getCart();

        // (Geri kalan canlı arama ve garaj modülü JS kodların aynı kaldı)
        function setupLiveSearch(inputId, resultsId) {
            const input = document.getElementById(inputId);
            const results = document.getElementById(resultsId);
            let searchTimer;

            if (!input || !results) return;

            input.addEventListener('input', function() {
                clearTimeout(searchTimer);
                let q = this.value.trim();

                if (q.length < 3) {
                    results.classList.remove('active');
                    if (!document.querySelector('.drawer-panel.active')) {
                        setPageScrollLock(false);
                    }
                    return;
                }

                if (window.innerWidth < 768) {
                    setPageScrollLock(true);
                }

                searchTimer = setTimeout(() => {
                    let fd = new FormData();
                    fd.append('action', 'live_search');
                    fd.append('q', q);

                    fetch('/index.php', { method:'POST', body:fd })
                        .then(r => r.json())
                        .then(d => {
                            results.innerHTML = window.innerWidth >= 768 ? d.htmlDesk : d.htmlMob;
                            results.classList.add('active');
                        });
                }, 400);
            });

            document.addEventListener('click', (e) => {
                if (!input.contains(e.target) && !results.contains(e.target)) {
                    results.classList.remove('active');
                    if (!document.querySelector('.drawer-panel.active')) {
                        setPageScrollLock(false);
                    }
                }
            });
        }

        setupLiveSearch('deskSearchInput', 'deskSearchResults');
        setupLiveSearch('mobSearchInput', 'mobSearchResults');

        const brandEl = document.getElementById('sel_brand');
        const modelEl = document.getElementById('sel_model');
        const yearEl = document.getElementById('sel_year');
        const btnEl = document.getElementById('btn_search_garage');
        let selectedGarageSlug = '';

        if (brandEl && modelEl && yearEl && btnEl) {
            brandEl.addEventListener('change', function () {
                modelEl.innerHTML = '<option value="">Model Seçin</option>';
                yearEl.innerHTML = '<option value="">Yıl / Kasa Seçin</option>';

                modelEl.disabled = true;
                modelEl.classList.add('opacity-60', 'cursor-not-allowed', 'bg-slate-100', 'text-slate-500');
                modelEl.classList.remove('bg-white', 'text-slate-900');

                yearEl.disabled = true;
                yearEl.classList.add('opacity-60', 'cursor-not-allowed', 'bg-slate-100', 'text-slate-500');
                yearEl.classList.remove('bg-white', 'text-slate-900');

                btnEl.disabled = true;
                btnEl.style.backgroundColor = '#475569';
                btnEl.style.color = '#fff';
                btnEl.style.cursor = 'not-allowed';
                selectedGarageSlug = '';

                if (!this.value) return;

                let fd = new FormData();
                fd.append('action', 'get_models');
                fd.append('brand_id', this.value);

                fetch('/index.php', { method:'POST', body:fd })
                    .then(r => r.json())
                    .then(d => {
                        if (d.status === 'ok' && d.results.length > 0) {
                            d.results.forEach(m => {
                                const o = document.createElement('option');
                                o.value = m.id;
                                o.textContent = m.brand_name;
                                modelEl.appendChild(o);
                            });

                            modelEl.disabled = false;
                            modelEl.classList.remove('opacity-60', 'cursor-not-allowed', 'bg-slate-100', 'text-slate-500');
                            modelEl.classList.add('bg-white', 'text-slate-900');
                        }
                    });
            });

            modelEl.addEventListener('change', function () {
                yearEl.innerHTML = '<option value="">Yıl / Kasa Seçin</option>';

                yearEl.disabled = true;
                yearEl.classList.add('opacity-60', 'cursor-not-allowed', 'bg-slate-100', 'text-slate-500');
                yearEl.classList.remove('bg-white', 'text-slate-900');

                btnEl.disabled = true;
                btnEl.style.backgroundColor = '#475569';
                btnEl.style.color = '#fff';
                btnEl.style.cursor = 'not-allowed';
                selectedGarageSlug = '';

                if (!this.value) return;

                let fd = new FormData();
                fd.append('action', 'get_years');
                fd.append('model_id', this.value);

                fetch('/index.php', { method:'POST', body:fd })
                    .then(r => r.json())
                    .then(d => {
                        if (d.status === 'ok' && d.results.length > 0) {
                            d.results.forEach(y => {
                                const o = document.createElement('option');
                                o.value = y.slug;
                                o.textContent = y.brand_name;
                                yearEl.appendChild(o);
                            });

                            yearEl.disabled = false;
                            yearEl.classList.remove('opacity-60', 'cursor-not-allowed', 'bg-slate-100', 'text-slate-500');
                            yearEl.classList.add('bg-white', 'text-slate-900');
                        }
                    });
            });

            yearEl.addEventListener('change', function () {
                selectedGarageSlug = this.value;

                if (this.value) {
                    btnEl.disabled = false;
                    btnEl.style.backgroundColor = '#a33600';
                    btnEl.style.color = '#fff';
                    btnEl.style.cursor = 'pointer';
                } else {
                    btnEl.disabled = true;
                    btnEl.style.backgroundColor = '#475569';
                    btnEl.style.color = '#fff';
                    btnEl.style.cursor = 'not-allowed';
                }
            });

            btnEl.addEventListener('click', function () {
                if (selectedGarageSlug) window.location.href = '/' + selectedGarageSlug;
            });
        }

        document.querySelectorAll('.cat-toggle').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                let icon = this.querySelector('i');
                let subList = this.parentElement.nextElementSibling;

                if (subList && subList.classList.contains('hidden')) {
                    subList.classList.remove('hidden');
                    icon.style.transform = 'rotate(180deg)';
                } else if (subList) {
                    subList.classList.add('hidden');
                    icon.style.transform = 'rotate(0deg)';
                }
            });
        });

        document.querySelectorAll('.product-link').forEach(link => {
            link.addEventListener('click', function(e) {
                if (this.href && !this.href.includes('#') && this.target !== '_blank') {
                    e.preventDefault();
                    const pageTransition = document.getElementById('pageTransition');
                    if (pageTransition) pageTransition.classList.add('active');
                    setTimeout(() => { window.location.href = this.href; }, 250);
                }
            });
        });

        const heroSlider = document.getElementById('mainHeroSlider');
        if (heroSlider && heroSlider.children.length > 1) {
            setInterval(() => {
                let scrollAmount = heroSlider.offsetWidth;
                if (heroSlider.scrollLeft + scrollAmount >= heroSlider.scrollWidth - 10) {
                    heroSlider.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    heroSlider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
                }
            }, 4000);
        }
    });

    // V2.17 - iPhone ana sayfa alt menü / üst menü drawer açma zırhı
    // Not: Header ve footer butonları bu global fonksiyonları kullanır.
    function drsDrawerOverlay() {
        return document.getElementById('drawerOverlay');
    }

    function drsFindDrawer(id) {
        var targetId = String(id || '');
        if (!targetId) return null;

        var panels = document.querySelectorAll('.drawer-panel');
        for (var i = 0; i < panels.length; i++) {
            if (panels[i].id === targetId) return panels[i];
        }

        return document.getElementById(targetId);
    }

    function closeDrawers() {
        document.querySelectorAll('.drawer-panel').forEach(function (drawerPanel) {
            drawerPanel.classList.remove('active');
            drawerPanel.setAttribute('aria-hidden', 'true');
        });

        var overlay = drsDrawerOverlay();
        if (overlay) {
            overlay.classList.remove('active');
            overlay.setAttribute('aria-hidden', 'true');
        }

        document.body.classList.remove('drs-drawer-open');
        setPageScrollLock(false);
    }

    function toggleDrawer(id) {
        if (typeof window.closeMobileSearch === 'function') {
            window.closeMobileSearch();
        }

        closeDrawers();

        var drawer = drsFindDrawer(id);
        var overlay = drsDrawerOverlay();

        if (!drawer) return false;

        drawer.classList.add('active');
        drawer.setAttribute('aria-hidden', 'false');

        if (overlay) {
            overlay.classList.add('active');
            overlay.setAttribute('aria-hidden', 'false');
        }

        document.body.classList.add('drs-drawer-open');

        if (shouldLockDrawerScroll()) {
            setPageScrollLock(true);
        }

        return false;
    }

    window.closeDrawers = closeDrawers;
    window.toggleDrawer = toggleDrawer;

    var drsLastMobileDrawerTapAt = 0;
    var drsLastMobileDrawerTapId = '';

    window.drsHandleMobileDrawerTap = function (event, id) {
        if (event) {
            if (typeof event.preventDefault === 'function') event.preventDefault();
            if (typeof event.stopPropagation === 'function') event.stopPropagation();
        }

        var now = Date.now ? Date.now() : new Date().getTime();
        var targetId = String(id || '');

        // iOS touchend sonrası click de üretebildiği için aynı dokunuşu tek işlem say.
        if (targetId === drsLastMobileDrawerTapId && (now - drsLastMobileDrawerTapAt) < 350) {
            return false;
        }

        drsLastMobileDrawerTapAt = now;
        drsLastMobileDrawerTapId = targetId;

        return toggleDrawer(targetId);
    };

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-drs-mobile-drawer-open]').forEach(function (btn) {
            var drawerId = btn.getAttribute('data-drs-mobile-drawer-open');
            if (!drawerId) return;

            btn.addEventListener('touchend', function (event) {
                window.drsHandleMobileDrawerTap(event, drawerId);
            }, { passive: false });
        });
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth >= 1024) {
            closeDrawers();
        }
    });

    </script>

<script src="/assets/js/site-search-submit.js?v=1.00" defer></script>



<script>
(function(){
    if (window.__DRS_ANALYTICS_SENT__) return;
    window.__DRS_ANALYTICS_SENT__ = true;

    var path = window.location.pathname || '/';
    if (/^\/(admin|analytics\/collect\.php|cart\/ajax_cart\.php)/i.test(path)) return;

    function cleanHost(host) {
        host = (host || '').toLowerCase().replace(/:\d+$/, '');
        return host.replace(/^www\./, '');
    }
    function domainKey(host) {
        var h = cleanHost(host);
        if (h === 'drstuning.com.tr') return 'drs_tr';
        if (h === 'otoaksesuarshop.com') return 'oto';
        return 'drs_com';
    }
    function randomId(prefix) {
        var cryptoObj = window.crypto || window.msCrypto;
        if (cryptoObj && cryptoObj.getRandomValues) {
            var arr = new Uint32Array(4);
            cryptoObj.getRandomValues(arr);
            return prefix + '_' + Array.prototype.map.call(arr, function(n){ return n.toString(16); }).join('');
        }
        return prefix + '_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2);
    }
    function storageGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
    function storageSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }

    var host = cleanHost(window.location.hostname);
    var dk = domainKey(host);
    var vKey = 'drs_ga_vid_' + dk;
    var sKey = 'drs_ga_sid_' + dk;
    var lKey = 'drs_ga_last_' + dk;
    var now = Date.now();
    var visitorId = storageGet(vKey);
    if (!visitorId) {
        visitorId = randomId('v');
        storageSet(vKey, visitorId);
    }
    var sessionId = storageGet(sKey);
    var lastSeen = parseInt(storageGet(lKey) || '0', 10);
    if (!sessionId || !lastSeen || (now - lastSeen) > (30 * 60 * 1000)) {
        sessionId = randomId('s');
        storageSet(sKey, sessionId);
    }
    storageSet(lKey, String(now));

    var params = new URLSearchParams(window.location.search || '');
    var payload = {
        event_id: randomId('ev'),
        event_name: 'page_view',
        domain_key: dk,
        site_host: host,
        visitor_id: visitorId,
        analytics_session_id: sessionId,
        user_id: 0,
        page_url: window.location.href,
        page_path: path + (window.location.search || ''),
        page_title: document.title || '',
        referrer_url: document.referrer || '',
        utm_source: params.get('utm_source') || '',
        utm_medium: params.get('utm_medium') || '',
        utm_campaign: params.get('utm_campaign') || '',
        language: navigator.language || '',
        screen_width: window.screen ? (window.screen.width || 0) : 0,
        screen_height: window.screen ? (window.screen.height || 0) : 0
    };

    function sendAnalytics() {
        var body = JSON.stringify(payload);
        var url = '/analytics/collect.php';
        if (navigator.sendBeacon) {
            try {
                var blob = new Blob([body], {type: 'application/json'});
                if (navigator.sendBeacon(url, blob)) return;
            } catch(e) {}
        }
        try {
            fetch(url, {
                method: 'POST',
                body: body,
                headers: {'Content-Type': 'application/json'},
                credentials: 'same-origin',
                keepalive: true
            }).catch(function(){});
        } catch(e) {}
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', sendAnalytics, {once:true});
    } else {
        sendAnalytics();
    }
})();
</script>

