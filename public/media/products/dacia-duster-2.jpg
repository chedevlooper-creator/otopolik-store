    <header class="w-full bg-white shadow-md sticky top-0" style="z-index:8000;">
        <div class="hidden md:flex max-w-[1350px] mx-auto px-4 pt-2 pb-0 justify-between items-center gap-8">
            <a href="/" title="DRS Tuning Anasayfa" aria-label="Anasayfa" class="shrink-0 flex items-center justify-start w-[350px]">
                <img
                    src="/uploads/theme/theme_6a22a2701d9136.40246203244_desk.webp"
                    alt="DRS Tuning Logo"
                    width="220"
                    height="56"
                    class="max-h-12 w-auto object-contain"
                    fetchpriority="high"
                    decoding="async"
                >
            </a>

            <div class="flex-1 max-w-4xl relative group w-full">
                <form action="/arama" method="GET" class="w-full relative flex items-center" id="deskSearchForm">
                    <label for="deskSearchInput" class="sr-only">Aracınız için parça arayın</label>
                    <input
                        type="text"
                        name="q"
                        id="deskSearchInput"
                        placeholder="Aracınız için parça, aksesuar arayın..."
                        autocomplete="off"
                        enterkeyhint="search"
                        inputmode="search"
                        aria-label="Arama kutusu"
                        class="w-full pl-8 pr-14 py-3.55 bg-slate-50 border-2 border-slate-200 rounded-xl outline-none focus:border-drs-primary focus:bg-white transition-all text-[15px] font-semibold text-slate-700 shadow-inner"
                    >
                    <button type="submit" aria-label="Ara" class="absolute right-1.5 top-1.5 bottom-1.5 w-14 bg-drs-safe text-white rounded-lg flex items-center justify-center transition-colors text-xl">
                        <i class="fa-solid fa-search" aria-hidden="true"></i>
                    </button>
                </form>
                <div class="live-search-results" id="deskSearchResults"></div>
            </div>

            <div class="flex items-center gap-6 shrink-0 w-[350px] justify-end">
                
