}

.drs-campaign-queue-count-row {
    display: none !important;
}

.drs-campaign-queue-bottom {
    margin-top: auto;
    align-items: flex-end;
}

.drs-campaign-queue-prices {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 3px 6px;
    min-width: 0;
}

.drs-campaign-queue-old {
    width: 100%;
    font-size: 9.5px;
}

.drs-campaign-queue-new {
    font-size: 15.5px;
}

.drs-campaign-queue-stock-inline {
    color: #047857;
    font-size: 9px;
    font-weight: 1000;
    white-space: nowrap;
}

.drs-campaign-queue-cart,
.drs-campaign-queue-waiting,
.drs-campaign-queue-disabled {
