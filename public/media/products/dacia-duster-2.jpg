}

.drs-campaign-queue-foot {
    display: none !important;
}

@media (min-width: 1024px) {
    .drs-campaign-queue-card {
        flex-basis: 82%;
        min-width: 82%;
        max-width: 82%;
    }
}

@media (max-width: 767px) {
    .drs-campaign-queue-box {
        min-height: 218px !important;
    }

    .drs-campaign-queue-card {
        min-height: 148px;
